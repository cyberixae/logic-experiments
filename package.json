  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/jest": "^29.5.12",
    "esbuild": "^0.27.3",
    "eslint": "^10.0.3",
    "jest": "^29.7.0",
    "prettier": "^3.2.5",
    "ts-jest": "^29.1.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.1"
  },
  "scripts": {
    "build:web": "esbuild --bundle src/web.ts > dist/lk.js",
    "dev": "esbuild --bundle src/web.ts --outfile=dist/lk.js --watch=forever --servedir=dist & open http://localhost:8000/lk.html",
    "build": "yarn tsc",
    "lk": "yarn build && node ./lib/lk.js",
    "la3": "yarn build && node ./lib/la3.js",
    "main": "yarn build && node ./lib/main.js",
    "namegen": "node scripts/namegen.ts",
    "prettify": "prettier . --write"
  }
}
